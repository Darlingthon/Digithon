{
  "name": "trustline",
  "private": true,
  "version": "0.0.0",
  "description": "TrustLine — an AI employee (Vera) that runs KYC end-to-end",
  "workspaces": [
    "packages/*",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "npm run generate --workspace @trustline/db",
    "db:migrate": "npm run migrate --workspace @trustline/db",
    "db:seed": "npm run seed --workspace @trustline/db",
    "db:reset": "npm run reset --workspace @trustline/db",
    "bootstrap": "npm install && npm run db:up && npm run db:generate && npm run db:migrate && npm run db:seed",
    "agent:dev": "cd apps/agent && python3 -m vera.main"
  },
  "engines": {
    "node": ">=20"
  }
}
