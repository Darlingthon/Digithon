# ─────────────────────────────────────────────────────────────
# TrustLine env — copy to .env and fill in. Never commit .env.
# (Comments live on their own lines so this file is safe to use as a
#  docker-compose `env_file`, which does not strip inline comments.)
# ─────────────────────────────────────────────────────────────

# Database. Local default matches docker-compose. In compose the app services
# override the host to `postgres`; on Cloud Run this is the Cloud SQL socket URL.
DATABASE_URL="postgresql://trustline:trustline@localhost:5432/trustline?schema=public"

# Web app base URL. For LIVE SMS this must be PUBLICLY reachable (a cloudflared
# https URL) so the texted link opens on the customer's phone — localhost won't.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Channels service wiring (live SMS / Vera calls from the web /new form) ──
# Where the web app reaches the channels service (server-side).
CHANNELS_URL="http://localhost:4000"
# Public URL of the CHANNELS service itself (cloudflared) — required for Vera
# voice calls so Twilio can fetch the TwiML and open the Media Streams bridge.
CHANNELS_PUBLIC_URL=""
# SMS questionnaire not filled within this window → Vera auto-calls.
# Default 24h; set short (e.g. 60000 = 60s) to demo the auto-call fallback live.
QUESTIONNAIRE_FALLBACK_MS="86400000"
# How often the channels service sweeps for stalled questionnaires.
QUESTIONNAIRE_SWEEP_MS="30000"

# ── Twilio (Track B: SMS / OTP / Voice) ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_VERIFY_SERVICE_SID=""
# The call-in / outbound voice number (E.164).
TWILIO_PHONE_NUMBER=""

# ── OpenAI (Track B: Vera voice, gpt-realtime) ──
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-2"

# ── Sumsub (Track C: IDV  +  Track A: AML screening) ──
SUMSUB_APP_TOKEN=""
SUMSUB_SECRET_KEY=""
SUMSUB_BASE_URL="https://api.sumsub.com"
# Sumsub verification level. Leave empty to run IDV in demo mode.
SUMSUB_LEVEL_NAME=""

# ── Google Cloud / ADK (Track A: Vera agent) ──
GOOGLE_GENAI_USE_VERTEXAI="false"
# AI Studio free-tier key, or configure Vertex/ADC for Cloud Run.
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-3-flash-preview"
GCP_PROJECT_ID=""
GCP_REGION="us-central1"

# ── cloudflared static (named) tunnel — see scripts/tunnel-setup.sh ──
# Your Cloudflare-managed apex domain; tunnels publish web.<domain> + channels.<domain>.
TUNNEL_DOMAIN=""

# cloudflared token mode (Zero Trust dashboard tunnel). See docs/DEPLOY.md.
CLOUDFLARE_TUNNEL_TOKEN=""
