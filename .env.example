# ─────────────────────────────────────────────────────────────
# TrustLine env — copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://trustline:trustline@localhost:5432/trustline?schema=public"

# App
# Web app base URL. For LIVE SMS, this must be PUBLICLY reachable (e.g. an ngrok
# https URL) so the texted link opens on the customer's phone — localhost won't.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Channels service wiring (live SMS / Vera calls from the web /new form) ──
# Where the web app reaches the channels service (server-side). Local default:
CHANNELS_URL="http://localhost:4000"
# Public URL of the CHANNELS service itself (ngrok) — required for Vera voice
# calls so Twilio can fetch the TwiML and open the Media Streams bridge.
CHANNELS_PUBLIC_URL=""
# SMS questionnaire not filled within this window → Vera auto-calls. Default 24h;
# set short (e.g. 60000 = 60s) to demo the auto-call fallback live.
QUESTIONNAIRE_FALLBACK_MS="86400000"
# How often the channels service sweeps for stalled questionnaires.
QUESTIONNAIRE_SWEEP_MS="30000"

# ── Twilio (Track B: SMS / OTP / Voice) ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_VERIFY_SERVICE_SID=""
TWILIO_PHONE_NUMBER=""          # the call-in / outbound number

# ── OpenAI (Track B: Vera voice, gpt-realtime-2) ──
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-2"

# ── Sumsub (Track C: IDV  +  Track A: AML screening) ──
SUMSUB_APP_TOKEN=""
SUMSUB_SECRET_KEY=""
SUMSUB_BASE_URL="https://api.sumsub.com"
SUMSUB_LEVEL_NAME=""            # sandbox verification level used when creating test applicants

# ── Google Cloud / ADK (Track A: Vera agent) ──
GOOGLE_GENAI_USE_VERTEXAI="false"
GOOGLE_API_KEY=""               # or configure Vertex/ADC for Cloud Run
GCP_PROJECT_ID=""
GCP_REGION="us-central1"
