{
  "name": "@trustline/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2"
  }
}
